# Copy to `.env` and fill in (never commit `.env`).
# Azure OpenAI — used by `app.py` (search decomposition + justifications).
# Put this file next to `app.py` as `.env` (same folder as `poc_wbce/app.py`).

OAI_BASE_LLM=https://YOUR_RESOURCE.openai.azure.com/
OAI_KEY_LLM=your-azure-openai-key-here
OAI_VERSION=2024-12-01-preview
LLM_MODEL_NAME=gpt-5-mini

# Alternative names (OpenAI SDK / Azure docs) — optional if you use OAI_* above:
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-openai-key-here
# OPENAI_API_VERSION=2024-12-01-preview

# Neo4j (defaults match `app.py` / `seed_neo4j.py`)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
